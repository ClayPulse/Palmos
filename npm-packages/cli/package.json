{
	"name": "@pulse-editor/cli",
	"version": "0.1.9",
	"license": "MIT",
	"bin": {
		"pulse": "dist/cli.js"
	},
	"type": "module",
	"engines": {
		"node": ">=16"
	},
	"scripts": {
		"build": "tsx build.ts",
		"dev": "tsx watch --include \"./src/**/*\" build.ts",
		"test": "prettier --check . && xo && ava",
		"link": "npm link",
		"pack": "npm run build && npm pack --pack-destination dist"
	},
	"files": [
		"dist"
	],
	"dependencies": {
		"@module-federation/enhanced": "2.0.1",
		"@module-federation/node": "2.7.32",
		"@module-federation/runtime": "2.0.1",
		"@pulse-editor/shared-utils": "^0.1.1-beta.76",
		"concurrently": "^9.2.1",
		"connect-livereload": "^0.6.1",
		"copy-webpack-plugin": "^14.0.0",
		"cors": "^2.8.6",
		"cross-env": "^10.1.0",
		"dotenv": "^17.3.1",
		"execa": "^9.6.1",
		"express": "^5.2.1",
		"glob": "^13.0.6",
		"html-webpack-plugin": "^5.6.6",
		"ink": "^6.8.0",
		"ink-select-input": "^6.2.0",
		"ink-spinner": "^5.0.0",
		"ink-text-input": "^6.0.0",
		"jszip": "^3.10.1",
		"livereload": "^0.10.3",
		"meow": "^14.1.0",
		"mini-css-extract-plugin": "^2.10.0",
		"openid-client": "^6.8.2",
		"rimraf": "^6.1.3",
		"ts-morph": "^27.0.2",
		"tsx": "^4.21.0",
		"webpack": "^5.105.2",
		"webpack-dev-server": "^5.2.3"
	},
	"devDependencies": {
		"@sindresorhus/tsconfig": "^8.1.0",
		"@types/connect-livereload": "^0.6.3",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.6",
		"@types/jszip": "^3.4.0",
		"@types/livereload": "^0.9.5",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"ava": "^6.4.1",
		"chalk": "^5.6.2",
		"eslint-config-xo-react": "^0.29.0",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"ink-testing-library": "^4.0.0",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"ts-node": "^10.9.2",
		"typescript": "^5.9.3",
		"xo": "^1.2.3"
	},
	"peerDependencies": {
		"react": "19.2.4",
		"react-dom": "19.2.4"
	},
	"ava": {
		"extensions": {
			"ts": "module",
			"tsx": "module"
		},
		"nodeArguments": [
			"--loader=ts-node/esm"
		]
	},
	"xo": {
		"extends": "xo-react",
		"prettier": true,
		"rules": {
			"react/prop-types": "off"
		}
	}
}
