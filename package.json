{
    "name": "pulse-editor",
    "version": "0.0.1",
    "private": true,
    "workspaces": [
        "web",
        "desktop",
        "mobile",
        "capacitor-plugin",
        "vscode-extension",
        "npm-packages/react-api",
        "npm-packages/shared-utils"
    ],
    "scripts": {
        "web-dev": "npm run dev --workspace=web",
        "web-build": "npm run build --workspace=web",
        "web-start": "npm run start --workspace=web",
        "desktop-dev": "npm run dev --workspace=desktop",
        "desktop-build": "npm run web-build && npm run build --workspace=desktop",
        "android-dev": "npm run web-build && npm run android-dev --workspace=mobile",
        "android-build": "npm run web-build && npm run android-build --workspace=mobile",
        "react-api-build": "npm run build --workspace=npm-packages/react-api",
        "shared-utils-build": "npm run build --workspace=npm-packages/shared-utils",
        "cli-dev": "npm run dev --workspace=cli",
        "cli-build": "npm run build --workspace=cli",
        "capacitor-plugin-build-android": "npm run verify:android --workspace=capacitor-plugin"
    },
    "devDependencies": {
        "@changesets/cli": "^2.29.4"
    }
}
